# NEJ Autos admin — protect sensitive files from direct web access.

# Never serve credentials, schema, docs, or the sample config over HTTP.
<FilesMatch "^(config\.php|config\.sample\.php|schema\.sql|README\.md)$">
  Require all denied
</FilesMatch>

# Hardening headers + keep the admin area out of search engines.
# All wrapped in IfModule so a host without mod_headers doesn't 500 the folder.
<IfModule mod_headers.c>
  Header set X-Robots-Tag "noindex, nofollow"
  Header set X-Content-Type-Options "nosniff"
  Header set X-Frame-Options "SAMEORIGIN"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
