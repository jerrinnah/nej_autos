# Uploaded car photos are static media only — never execute code here.
# php_flag only works under mod_php, so guard it or it 500s under PHP-FPM/LiteSpeed.
<IfModule mod_php.c>
  php_flag engine off
</IfModule>
<IfModule mod_php7.c>
  php_flag engine off
</IfModule>
<IfModule mod_php8.c>
  php_flag engine off
</IfModule>

# Cross-handler safe way to block script execution in this folder.
<FilesMatch "\.(php|phtml|php3|php4|php5|php7|php8|phar|cgi|pl|py|sh|html?)$">
  Require all denied
</FilesMatch>
